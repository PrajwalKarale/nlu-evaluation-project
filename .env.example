# Supabase PostgreSQL connection string
# Get this from: Supabase Dashboard → Project Settings → Database → Connection String
# Use port 5432 (direct connection) for ingestion
# Use port 6543 (transaction pooling) for the Flask app
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
